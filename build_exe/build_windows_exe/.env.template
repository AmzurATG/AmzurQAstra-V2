# ─────────────────────────────────────────────────────────────
#  QAstra Configuration
#  Fill in the values below, then double-click QAstra.exe
# ─────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME
# Examples:
#   Local:  postgresql://postgres:secret@localhost:5432/qastra
#   Remote: postgresql://admin:pass@192.168.1.10:5432/qastra

# ── Security (required) ──────────────────────────────────────
# Generate random values: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE-ME
ENCRYPTION_KEY=CHANGE-ME

# ── LLM Provider (at least one required) ─────────────────────
DEFAULT_LLM_PROVIDER=litellm
LITELLM_API_KEY=your-key
LITELLM_API_BASE=https://your-proxy.example.com
LITELLM_MODEL=gpt-4o

# Direct provider keys (alternative to LiteLLM proxy):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── App Settings ─────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ── Admin Account ────────────────────────────────────────────
ADMIN_EMAIL=admin@qastra.dev
ADMIN_PASSWORD=change-me-on-first-login

# ── Optional ─────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
