# Backend Environment Configuration
# Copy to .env and update values

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://qastra:qastra123@localhost:5432/qastra
# Schema per stakeholder (each user gets their own schema in the same DB) — REQUIRED
DB_SCHEMA=your_schema_name

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ENCRYPTION_KEY=your-32-character-encryption-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Configuration
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEFAULT_LLM_PROVIDER=litellm
DEFAULT_LLM_MODEL=gpt-4-turbo-preview

# LiteLLM Configuration (Unified LLM Proxy)
# Use LiteLLM for accessing multiple LLM providers with a single API
LITELLM_API_KEY=your-litellm-api-key
LITELLM_API_BASE=http://localhost:4000/v1  # OpenAI-compatible base; include /v1 if your proxy expects it
LITELLM_MODEL=gpt-4  # e.g. gemini/gemini-2.5-flash for vision-capable Gemini via proxy
# Optional: comma-separated fallbacks if the primary model errors (client retries in order)
LITELLM_FALLBACK_MODELS=gpt-4o,gpt-4o-mini

# Browser-use agent LLM (default: same LiteLLM proxy as the API — use a vision model)
BROWSER_USE_LLM_BACKEND=litellm
# Optional: override model for browser only (else LITELLM_MODEL)
# BROWSER_USE_LLM_MODEL=gemini/gemini-2.5-flash
BROWSER_USE_LLM_TEMPERATURE=0.15

# Direct Google Gemini for browser-use only (when BROWSER_USE_LLM_BACKEND=google)
GEMINI_API_KEY=

# MCP Server
MCP_SERVER_URL=http://localhost:3001

# Jira Integration (optional)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Azure DevOps Integration (optional)
AZURE_DEVOPS_ORG_URL=
AZURE_DEVOPS_PAT=

# Slack Integration (optional)
SLACK_WEBHOOK_URL=

# ============================================
# Document Storage Configuration
# ============================================
# Storage type: 'local', 's3', or 'supabase'
STORAGE_TYPE=local

# Local Storage
# Path should be outside backend folder to prevent uvicorn restart
# Default: ../storage (resolves to QAstra/storage/)
STORAGE_LOCAL_PATH=../storage

# AWS S3 Storage (uncomment and configure to use)
# STORAGE_S3_BUCKET=your-bucket-name
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=your-access-key
# STORAGE_S3_SECRET_KEY=your-secret-key
# STORAGE_S3_ENDPOINT_URL=  # For S3-compatible services (MinIO, DigitalOcean, etc.)
# STORAGE_S3_PREFIX=uploads

# Supabase Storage (uncomment and configure to use)
# STORAGE_SUPABASE_URL=https://your-project.supabase.co
# STORAGE_SUPABASE_KEY=your-service-role-key
# STORAGE_SUPABASE_BUCKET=documents
# STORAGE_SUPABASE_PREFIX=

# ============================================
# Legacy File Storage (for backward compatibility)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Requirement uploads: max size in bytes (default 5 MiB = 5,242,880)
# REQUIREMENT_UPLOAD_MAX_BYTES=5242880

# Logging
LOG_LEVEL=INFO
